@model List<TicketManagementSystem.DTOs.Department.DepartmentListDto>;

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>This is the list of all Departments</h1>
    <button type="button" id="createDepartmentBtn" class="btn btn-success">Add Department</button>
</div>

<div class="row">
    @{
        var index = 1;
    }
    <table class="table">
        <thead>
            <tr>
                <th>S.N</th>
                <th>Name</th>
                
            </tr>

        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@index</td>
                    <td>@item.Name</td>
                    
                    <td>
                        <a >Edit</a> |
                        <a href="javascript:void(0);" class="text-danger" onclick="openDeleteModal(@item.DepartmentId)">Delete</a>
                    </td>
                </tr>
                index++;
            }
        </tbody>
    </table>

    <div class="modal fade" id="createDepartmentModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content" id="createDepartmentModalContent"></div>
        </div>
    </div>

    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content" id="deleteModalContent">
            </div>
        </div>
    </div>

</div>

@section Scripts{
    <script src="~/js/department.js" asp-append-version="true"></script>
}
