@model List<TicketManagementSystem.DTOs.Ticket.TicketListDto>
@{
    var currentUser = ViewBag.CurrentUser;
    var filter = ViewBag.Filter as TicketManagementSystem.DTOs.Ticket.TicketFilterDto
                 ?? new TicketManagementSystem.DTOs.Ticket.TicketFilterDto();
}


<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <h1 class="mb-0">My Tickets</h1>
    <button type="button" id="createTicketBtn" class="btn btn-success">
        + Create Ticket
    </button>
</div>


<form method="get" asp-action="Index" class="card p-3 mb-4">
    <div class="row g-2 align-items-end">

        <div class="col-12 col-sm-6 col-md-2">
            <label class="form-label small mb-1">Search</label>
            <input name="Search"
                   value="@filter.Search"
                   class="form-control form-control-sm"
                   placeholder="Title, description, ticket no…" />
        </div>

        <div class="col-12 col-sm-6 col-md-2">
            <label class="form-label small mb-1">Status</label>
            <select name="StatusId" class="form-select form-select-sm">
                <option value="">-- Select --</option>
                @foreach (var s in ViewBag.Statuses as List<TicketManagementSystem.Models.Status>)
                {
                    <option value="@s.StatusId" selected="@(filter.StatusId == s.StatusId)">@s.Name</option>
                }
            </select>
        </div>

        <div class="col-12 col-sm-6 col-md-2">
            <label class="form-label small mb-1">Priority</label>
            <select name="PriorityId" class="form-select form-select-sm">
                <option value="">-- Select --</option>
                @foreach (var p in ViewBag.Priorities as List<TicketManagementSystem.Models.Priority>)
                {
                    <option value="@p.PriorityId" selected="@(filter.PriorityId == p.PriorityId)">@p.Name</option>
                }
            </select>
        </div>

        <div class="col-12 col-sm-6 col-md-2">
            <label class="form-label small mb-1">Department</label>
            <select name="DepartmentId" class="form-select form-select-sm">
                <option value="">-- Select --</option>
                @foreach (var d in ViewBag.Departments as List<TicketManagementSystem.Models.Department>)
                {
                    <option value="@d.DepartmentId" selected="@(filter.DepartmentId == d.DepartmentId)">@d.Name</option>
                }
            </select>
        </div>

        <div class="col-12 col-sm-6 col-md-2">
            <label class="form-label small mb-1">Category</label>
            <select name="CategoryId" class="form-select form-select-sm">
                <option value="">-- Select --</option>
                @foreach (var c in ViewBag.Categories as List<TicketManagementSystem.Models.Category>)
                {
                    <option value="@c.CategoryId" selected="@(filter.CategoryId == c.CategoryId)">@c.Name</option>
                }
            </select>
        </div>

        <div class="col-12 col-sm-6 col-md-2 d-flex gap-2 align-items-end">
            <button type="submit" class="btn btn-primary btn-sm w-50">Apply</button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-50 text-center">Clear</a>
        </div>

    </div>

    <div class="row g-2 align-items-end mt-2">
        <div class="col-12 col-sm-6 col-md-2">
            <label class="form-label small mb-1">Sort By</label>
            <select name="SortBy" class="form-select form-select-sm">
                <option value="">Select</option>
                <option value="CreatedDate" selected="@(filter.SortBy == "CreatedDate")">Date</option>
                <option value="Priority" selected="@(filter.SortBy == "Priority")">Priority</option>
                <option value="Status" selected="@(filter.SortBy == "Status")">Status</option>
                <option value="Title" selected="@(filter.SortBy == "Title")">Title</option>
            </select>
        </div>

        <div class="col-12 col-sm-6 col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary btn-sm">Apply</button>
        </div>

        <div class="col-12 col-md-8 d-flex align-items-end justify-content-md-end">
            <span class="text-muted small">
                @Model.Count ticket@(Model.Count != 1 ? "s" : "")
            </span>
        </div>

    </div>

</form>

<div class="table-responsive">
    <table class="table table-hover table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>S.N</th>
                <th>Ticket No</th>
                <th>Title</th>
                <th>Description</th>
                <th>Priority</th>
                <th>Category</th>
                <th>Status</th>
                <th>Department</th>
                <th>Created On</th>
                <th>Created By</th>
                <th>Currently Assigned</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="12" class="text-center text-muted py-4">
                        No tickets match your filters.
                        <a asp-action="Index">Clear filters</a>
                    </td>
                </tr>
            }
            @{
                var index = 1;
            }
            @foreach (var item in Model)
            {
                <tr id="ticketRow-@item.Id" style="cursor:pointer;">
                    <td>@index</td>
                    <td>
                        <a href="/Ticket/Details/@item.Id" style="text-decoration:none;">
                            @item.TicketNo
                        </a>
                    </td>
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>@item.Priority</td>
                    <td>@item.Category</td>
                    <td>@item.Status</td>
                    <td>@item.Department</td>
                    <td>@item.CreatedDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.CreatedByFullName</td>
                    <td>
                        @if (string.IsNullOrEmpty(item.AssignedToFullName))
                        {
                            <span class="text-muted">Unassigned</span>
                        }
                        else
                        {
                            @item.AssignedToFullName
                        }
                    </td>
                    @if (item.AssignedToUserId == currentUser || item.CreatedByUserId == currentUser)
                    {
                        <td class="text-nowrap">
                            <a href="/Ticket/Edit/@item.Id" class="me-1">Edit</a> |
                            <a href="javascript:void(0);" class="text-danger ms-1"
                               onclick="openDeleteModal(@item.Id)">Delete</a>
                        </td>
                    }
                    else
                    {
                        <td><i class="text-muted">No Access</i></td>
                    }
                </tr>
                index++;
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" id="deleteModalContent"></div>
    </div>
</div>

<div class="modal fade" id="createTicketModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" id="createTicketModalContent"></div>
    </div>
</div>

<div class="modal fade" id="editTicketModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" id="editTicketModalContent"></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ticket.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            console.log("Button found:", $('#createTicketBtn').length);
        });
    </script>
}

