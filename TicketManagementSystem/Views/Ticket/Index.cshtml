@model List<TicketManagementSystem.DTOs.Ticket.TicketListDto>;
@{
    var currentUser = ViewBag.CurrentUser;
}



<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>This is the list of all tickets</h1>
    <button type="button" id="createTicketBtn" class="btn btn-success">+ Create Ticket</button>
</div>

<div class="row">
    @{
        var index = 1;
    }
<table class="table">
  <thead>
      <tr>
            <th>S.N</th>
            <th>Ticket No</th>
            <th>Title</th>
            <th>Description</th>
            <th>Priority</th>
            <th>Category</th>
            <th>Status</th>
            <th>Department</th>
            <th>Created On</th>
            <th>CreatedBy</th>
            <th>CurrentlyAssigned</th>
            <th>Action</th>
      </tr>
            
  </thead>
   <tbody>
            @foreach (var item in Model)
            {
                <tr id="ticketRow-@item.Id" style="cursor:pointer;">
                    <td>@index</td>
                    <td>
                        <a href="/Ticket/Details/@item.Id" style="text-decoration: none;">
                            @item.TicketNo
                        </a>
                    </td>
                    
                   
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>@item.Priority</td>
                    <td>@item.Category</td>
                    <td>@item.Status</td>
                    <td>@item.Department</td>
                    <td>@item.CreatedDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.CreatedByFullName</td>
                    <td>
                        @if (string.IsNullOrEmpty(item.AssignedToFullName))
                        {
                            <span class="text-muted">Unassigned</span>
                        }
                        else
                        {
                            @item.AssignedToFullName
                        }
  
                    </td>
                    @if (item.AssignedToUserId == currentUser || item.CreatedByUserId == currentUser)
                    {
                            <td>
                                <a href="/Ticket/Edit/@item.Id">Edit</a>|
                                <a href="javascript:void(0);" class="text-danger" onclick="openDeleteModal(@item.Id)">Delete</a>
                            </td>
                       
                        
                    }
                    else
                    {
                        <td><i>No Edit/Delet Access</i></td>
                    }
                    
                </tr>
                index++;
            }
   </tbody>
</table>
</div>
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" id="deleteModalContent">

        </div>
    </div>
</div>

<div class="modal fade" id="createTicketModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" id="createTicketModalContent"></div>
    </div>
</div>
<div class="modal fade" id="editTicketModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" id="editTicketModalContent"></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ticket.js" asp-append-version="true"></script>
    <script>
        // Debug: confirm button exists at DOM ready
        $(document).ready(function () {
            console.log("Button found:", $('#createTicketBtn').length); // should be 1
        });
    </script>
}
