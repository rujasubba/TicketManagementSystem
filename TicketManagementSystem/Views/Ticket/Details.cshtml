@model TicketManagementSystem.Models.Ticket

<div class="container mt-4">
    <div class="mb-4">
        <h3>@Model.TicketNo - @Model.Title</h3>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow mb-4">
                <div class="card-header bg-light">
                    <strong>Activity</strong>
                </div>
                <div class="card-body" id="commentsSection" ticket-id="@Model.Id" style="max-height: 500px; overflow-y: auto;">

                    @if (Model.Comments != null && Model.Comments.Any())
                    {
                        foreach (var comment in Model.Comments.OrderByDescending(x => x.CreatedDate))
                        {
                            <div class="mb-3 border-bottom pb-2">
                                <div>
                                    <small>@comment.CreatedByUser?.FullName</small><br />
                                    <small class="text-muted">@comment.CreatedDate.ToString("yyyy-MM-dd hh:mm tt")</small>
                                </div>
                                <div>@comment.Content</div>
                                @if (comment.Attachments != null && comment.Attachments.Any())
                                    {
                                            <ul class="list-group mt-2">
                                             @foreach (var file in comment.Attachments)
                                              {
                                                  <li class="list-group-item d-flex justify-content-between">
                                                  <span>@file.FileName</span>

                                                 @* <a href="@file.FilePath" class="comment-attachment-view" target="_blank">View</a> *@


                                                 @{
                                                  var filePath = file.FilePath.StartsWith("/") ? file.FilePath : "/" + file.FilePath;
                                                  var isImage = System.Text.RegularExpressions.Regex.IsMatch(filePath, @"\.(jpg|jpeg|png|gif|bmp|webp|svg)$", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                                                  }

                                         @if (isImage)
                                             {
                                               <a class="btn btn-sm btn-outline-primary img-view-btn"
                                                  data-img-path="@filePath"
                                                  data-img-name="@file.FileName">
                                                  <i class="bi bi-eye"></i> View
                                               </a>
                                            }
                                        else
                                            {
                                              <a href="@filePath" target="_blank"
                                              class="btn btn-sm btn-outline-primary">
                                               <i class="bi bi-eye"></i> View
                                             </a>
                                             }
                                         </li>
                                                }
                                       </ul>
                                     }
                                
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No comments yet.</p>
                    }

                </div>
                <div class="card-footer">
                    <textarea id="newCommentContent" class="form-control mb-2"
                              rows="2" placeholder="Add a comment..."></textarea>

                   
                    <div class="mb-2">
                        <label class="form-label small text-muted">Attachments (optional)</label>
                        <div class="attachmentsContainer">
                            <input type="file" id="commentAttachments" class="form-control form-control-sm"
                                   multiple accept="*/*" />
                            <div id="attachmentPreview" class="mt-1 d-flex flex-wrap gap-1"></div>
                        </div>
                        
                        <button type="button" id="addAttachmentBtn" class="btn btn-success btn-sm mt-2">
                            + Add Another Attachment
                        </button>
                    </div>
                    

                    <button id="addCommentBtn" class="btn btn-primary btn-sm">
                        <i class="bi bi-send"></i> Add Comment
                    </button>
                </div>

               
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-header bg-light">
                    <strong>Ticket Details</strong>
                </div>
                <div class="card-body">
                    <p><strong>Status:</strong> @Model.Status?.Name</p>
                    <p><strong>Priority:</strong> @Model.Priority?.Name</p>
                    <p><strong>Category:</strong> @Model.Category?.Name</p>
                    <p><strong>Department:</strong> @Model.Department?.Name</p>
                    <p><strong>Created By:</strong> @Model.CreatedByUser?.FullName</p>
                    <p><strong>Assigned To:</strong> @Model.AssigenedUser?.FullName</p>
                    <p><strong>Created On:</strong> @Model.CreatedDate.ToString("yyyy-MM-dd hh:mm tt")</p>
                </div>
            </div>

            <div class="card shadow mt-4">
                <div class="card-header bg-light">
                    <strong>Attachments</strong>
                </div>
                <div class="card-body">
                    @if (Model.Attachments != null && Model.Attachments.Any())
                    {
                        <ul class="list-group">
                            @foreach (var attachment in Model.Attachments)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span class="text-truncate me-2">@attachment.AttachmentName</span>
                                    <a href="/@attachment.AttachmentPath"
                                       target="_blank"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-download"></i> Download
                                    </a>
                                    <a class="btn btn-sm btn-outline-primary img-view-btn"
                                       data-img-path="@attachment.AttachmentPath"
                                       data-img-name="@attachment.AttachmentName">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">No attachments.</p>
                    }
                </div>
               
                <div class="modal fade" id="imagePreviewModal" tabindex="-1">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Image Preview</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body text-center">
                                <img id="previewImage" src="" alt="Preview" class="img-fluid" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow mt-4">
                <div class="card-header bg-light">
                    <strong>Ticket History</strong>
                </div>
                <div class="card-body" style="max-height: 300px; overflow-y: auto;">

                    @if (Model.TicketLogs != null && Model.TicketLogs.Any())
                    {
                        foreach (var log in Model.TicketLogs.OrderByDescending(x => x.AssignedDate))
                        {
                            <div class="mb-3 border-bottom pb-2">
                                <div>
                                    <small>
                                        <strong>@log.AssignedUser?.FullName</strong>
                                    </small>
                                    <br />
                                    <small class="text-muted">
                                        @log.AssignedDate.ToString("yyyy-MM-dd hh:mm tt")
                                    </small>
                                </div>

                                <div>
                                    @if (log.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No assignment history.</p>
                    }

                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/ticket.js" asp-append-version="true"></script>
    
}