@model TicketManagementSystem.DTOs.Ticket.CreateTicketDto

<div class="modal-header bg-primary text-white justify-content-between p-3">
    <h5 class="modal-title">Create Ticket</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">

        <form asp-controller="Ticket"
              asp-action="@(Model.Id > 0 ? "Edit" : "Create")"
              method="post"
              id="createTicketForm"
          enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label>Title</label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Description</label>
            <textarea asp-for="Description" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Priority</label>
            <select asp-for="Priority" class="form-control">
                <option value="">-- Select --</option>
                @foreach (var item in ViewBag.Priorities)
                {
                    <option value="@item.PriorityId">@item.Name</option>
                }
            </select>
            <span asp-validation-for="Priority" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Category</label>
            <select asp-for="Category" class="form-control">
                <option value="">-- Select --</option>
                @foreach (var item in ViewBag.Categories)
                {
                    <option value="@item.CategoryId">@item.Name</option>
                }
            </select>
            <span asp-validation-for="Category" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Assigned To</label>
            <select asp-for="AssignedUser" class="form-control">
                <option value="">-- Select --</option>
                @foreach (var item in ViewBag.Users)
                {
                    <option value="@item.Id">@item.FullName</option>
                }
            </select>
            <span asp-validation-for="AssignedUser" class="text-danger"></span>
        </div>

        @if (Model.Id > 0)
        {
            

            <div class="mb-3">
                <label>Status</label>
                <select asp-for="Status" class="form-control">
                    <option value="">-- Select --</option>
                    @foreach (var item in ViewBag.Statuses)
                    {
                        <option value="@item.StatusId">@item.Name</option>
                    }
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
        }

        

        <div class="mb-3">
            <label>Department</label>
            <select asp-for="Department" class="form-control">
                <option value="">-- Select --</option>
                @foreach (var item in ViewBag.Departments)
                {
                    <option value="@item.DepartmentId">@item.Name</option>
                }
            </select>
            <span asp-validation-for="Department" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Select File</label>

            @if (Model.Id > 0 && Model.ExistingAttachments != null && Model.ExistingAttachments.Any())
            {
                <div class="mb-2">
                    <label class="text-muted small">Current Attachments:</label>
                    <ul class="list-group mb-2" id="existingAttachmentsList">
                        @foreach (var file in Model.ExistingAttachments)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center py-1"
                                data-attachment-id="@file.Id">
                                <a href="/@file.AttachmentPath" target="_blank">@file.AttachmentName</a>
                                <div>
                                    <input type="hidden"
                                           name="RemovedAttachmentIds"
                                           value="@file.Id"
                                           class="remove-attachment-input"
                                           disabled />
                                    <button type="button" class="btn btn-danger btn-sm remove-attachment-btn">
                                        Remove
                                    </button>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }

            <input type="file" asp-for="Attachments" multiple class="form-control" />
            <button type="submit" class="btn btn-primary btn-group-sm mt-1">Upload</button>
        </div>
        <div class="mb-3">
            <label>Comments</label>

            <div id="commentsContainer">
                <div class="comment-item mb-2">
                    <textarea name="CommentContents[0]" class="form-control" placeholder="Add comment"></textarea>
                </div>
            </div>

            <button type="button" id="addCommentBtn" class="btn btn-success btn-sm mt-2">
                + Add Another Comment
            </button>
        </div>
        <div class="modal-footer">
            <button type="submit" class="btn btn-primary">
                @(Model.Id > 0 ? "Update Ticket" : "Add Ticket")
            </button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        </div>
    </form>
</div>


@section Scripts {
    <script src="~/js/createTicket.js"></script>
}


