@model TicketManagementSystem.Models.Ticket

@{
    ViewData["Title"] = "Create Ticket";
}

<div class="container mt-4">

    <h2>Create Ticket</h2>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label class="form-label">Title</label>
            <input asp-for="Title" class="form-control" placeholder="Enter ticket title" />
        </div>

        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="4"
                      placeholder="Describe the issue"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Category</label>
            <select asp-for="CategoryId" class="form-control"
                    asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                <option value="">-- Select Category --</option>
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Priority</label>
            <select asp-for="PriorityId" class="form-control"
                    asp-items="@(new SelectList(ViewBag.Priorities, "Id", "Name"))">
                <option value="">-- Select Priority --</option>
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Status</label>
            <select asp-for="StatusId" class="form-control"
                    asp-items="@(new SelectList(ViewBag.Statuses, "Id", "Name"))">
                <option value="">-- Select Status --</option>
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Assign To (Optional)</label>
            <select asp-for="AssignedToUserId" class="form-control"
                    asp-items="@(new SelectList(ViewBag.Users, "Id", "FirstName"))">
                <option value="">-- Not Assigned --</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary">
            Create Ticket
        </button>

        <a asp-action="Index" class="btn btn-secondary ms-2">
            Cancel
        </a>

    </form>

</div>