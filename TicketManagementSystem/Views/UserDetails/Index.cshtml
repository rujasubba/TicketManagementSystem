@model List<TicketManagementSystem.DTOs.UserListDto>
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Users</h1>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No users found.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Age</th>
                        <th>Department</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.FirstName @user.LastName</td>
                            <td>@user.Email</td>
                            <td>@user.PhoneNumber</td>
                            <td>@(user.Age.HasValue ? user.Age.ToString() : "-")</td>
                            <td>@(user.DepartmentName ?? "-")</td>
                            
                            <td class="text-end">
                                @if (user.HasDetails)
                                {
                                    <a asp-controller="UserDetails"
                                           asp-action="Details"
                                           asp-route-id="@user.UserId"
                                           class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    <a asp-controller="UserDetails"
                                           asp-action="Edit"
                                           asp-route-id="@user.UserId"
                                           class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                }
                                else
                                {
                                    
                                    <a asp-controller="UserDetails"
                                           asp-action="Create"
                                           asp-route-userId="@user.UserId"
                                           class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-plus-lg"></i> Add Details
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}


