@model TicketManagementSystem.DTOs.UserDetailsDto
@{
    ViewData["Title"] = "Add User Details";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-4">Enter User Details</h5>

                <div id="formErrors" class="alert alert-danger" style="display:none;"></div>
                <div id="formSuccess" class="alert alert-success" style="display:none;"></div>

                <form id="userDetailsForm">
                    @Html.AntiForgeryToken()

                    
                    <div class="form-floating mb-3">
                        <select asp-for="UserId"
                                asp-items="ViewBag.UserSelectList"
                                class="form-select"
                                id="userDropdown">
                            <option value="">-- Select User --</option>
                        </select>
                        <label asp-for="UserId">Select User</label>
                        <span asp-validation-for="UserId" class="text-danger"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="FirstName" class="form-control" id="FirstName" />
                                <label asp-for="FirstName">First Name</label>
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="LastName" class="form-control" id="LastName" />
                                <label asp-for="LastName">Last Name</label>
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email"
                               class="form-control"
                               id="Email"
                               placeholder="name@example.com" />
                        <label asp-for="Email">Email</label>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="PhoneNumber" class="form-control" id="PhoneNumber" />
                                <label asp-for="PhoneNumber">Phone Number</label>
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Age" class="form-control" id="Age" />
                                <label asp-for="Age">Age</label>
                                <span asp-validation-for="Age" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Address" class="form-control" id="Address" />
                        <label asp-for="Address">Address</label>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    
                    <div class="form-floating mb-4">
                        <select asp-for="DepartmentId"
                                asp-items="ViewBag.Departments"
                                class="form-select"
                                id="DepartmentId">
                            <option value="">-- Select Department --</option>
                        </select>
                        <label asp-for="DepartmentId">Department</label>
                        <span asp-validation-for="DepartmentId" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button id="userDetailsSubmit" type="button" class="btn btn-primary w-100">
                            <span id="submitSpinner"
                                  class="spinner-border spinner-border-sm me-1"
                                  style="display:none;"
                                  role="status"></span>
                            Save
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">Cancel</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const usersData = @Html.Raw(ViewBag.UsersJson);
    </script>

    <script src="~/js/userDetails.js"></script>

    
}